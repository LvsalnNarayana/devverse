{
  "_meta": {
    "description": "Declarative listing-page config consumed by ModuleListingLayout.",
    "flow": [
      "Page wrapper selects one module key (e.g. dsa, caseStudies).",
      "Page passes dataset, tags, and optionsBySource arrays.",
      "ModuleListingLayout applies filters/sorts/pagination based on this JSON."
    ],
    "importantKeys": {
      "filters.selects[].optionsSource": "Lookup key in optionsBySource passed by page.",
      "filters.selects[].visibleWhen": "Conditional visibility based on another select value.",
      "filters.selects[].resetOnHide": "Reset hidden select back to All when it becomes invisible.",
      "card.linkTemplate": "Interpolates item fields, e.g. /case-studies/:id"
    }
  },
  "dsa": {
    "header": {
      "backTo": "/",
      "title": "DSA Visualizer",
      "description": "Data structures, graph algorithms, sorting, searching, dynamic programming, classic problems, and techniques - filter by category, difficulty, tags, or structure type."
    },
    "filters": {
      "searchPlaceholder": "Search by title, tag, category, difficulty, or key point...",
      "searchKeys": [
        "title",
        "description",
        "tags",
        "category",
        "keyPoints",
        "id"
      ],
      "selects": [
        {
          "key": "category",
          "label": "Category",
          "optionsSource": "dsaCategories"
        },
        {
          "key": "structureKind",
          "label": "Structure type",
          "optionsSource": "dsaStructureKinds",
          "visibleWhen": {
            "key": "category",
            "in": [
              "All",
              "Data Structures"
            ]
          },
          "resetOnHide": true
        },
        {
          "key": "difficulty",
          "label": "Difficulty",
          "optionsSource": "dsaDifficulties"
        },
        {
          "key": "interviewFrequency",
          "label": "Interview frequency",
          "optionsSource": "dsaFrequencies"
        }
      ],
      "defaultSelectValues": {
        "category": "All",
        "structureKind": "All",
        "difficulty": "All",
        "interviewFrequency": "All"
      },
      "sorts": [
        {
          "value": "category",
          "label": "Category",
          "key": "categoryRank",
          "direction": "asc"
        },
        {
          "value": "title",
          "label": "Title A-Z",
          "key": "title",
          "direction": "asc"
        },
        {
          "value": "difficulty",
          "label": "Difficulty",
          "key": "difficultyRank",
          "direction": "asc"
        },
        {
          "value": "frequency",
          "label": "Interview frequency",
          "key": "frequencyRank",
          "direction": "desc"
        }
      ],
      "defaultSort": "category"
    },
    "card": {
      "type": "topic",
      "descriptionLines": 3,
      "minHeight": 280
    },
    "pagination": {
      "pageSize": 9
    },
    "emptyMessage": "No topics match your filters."
  },
  "caseStudies": {
