      "selects": [
        {
          "key": "category",
          "label": "Category",
          "optionsSource": "caseStudyCategories"
        }
      ],
      "sorts": [
        {
          "value": "title",
          "label": "Title A-Z",
          "key": "title",
          "direction": "asc"
        },
        {
          "value": "category",
          "label": "Category",
          "key": "category",
          "direction": "asc"
