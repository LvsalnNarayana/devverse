{
  "_meta": {
    "description": "Catalog of visualization types used by DSA topic pages.",
    "flow": [
      "dsaTopicPages.js maps topic id -> visualizationId",
      "visualizationRegistry.js lazy-loads the React component for each id",
      "DSATopicLayout renders the loaded component in the main column"
    ],
    "kinds": {
      "array-bars": "Bar chart on array indices (search, sort)",
      "linked-list": "Nodes with next pointers",
      "stack": "Vertical LIFO blocks",
      "queue": "Horizontal FIFO blocks",
      "heap": "Binary heap tree layout",
      "tree": "General tree / BST layout",
      "graph": "Nodes and edges",
      "matrix": "2D grid cells",
      "sorting": "Array bars with sort-specific highlights"
    }
  },
  "binary-search": {
    "kind": "array-bars",
    "label": "Binary Search (sorted array)",
    "status": "ready"
  },
